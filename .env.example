ENV=local
APP_TITLE="GitLab -> Telegram Notifier"
APP_NAME=git_notification
DEBUG=true

# NOTE: POSTGRES_HOST is intentionally NOT set here.
#   - Local dev (task run): defaults to "localhost".
#   - Docker Compose: the "app" service receives POSTGRES_HOST=postgres via the
#     compose `environment:` block. dotenv values override process env in this
#     project (see settings.settings_customise_sources), so leaving the host out
#     of this file is what lets Compose inject it.
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=git_notification

SENTRY_DSN=
PROMETHEUS_METRICS_KEY=change-me-metrics-key

# --- Telegram bot (aiogram, webhook mode) ---
# Get the token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Public HTTPS base URL where this service is reachable. Use ngrok or cloudflared
# for local development. Leave empty to skip webhook registration on startup.
TELEGRAM_WEBHOOK_URL=
# Secret echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=change-me-telegram-secret
# TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# --- GitLab webhook ---
# Must match the "Secret token" configured on the GitLab project webhook.
GITLAB_WEBHOOK_SECRET=change-me-gitlab-secret
